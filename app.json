{
  "expo": {
    "name": "cricket-umpire-ball-counter",
    "slug": "cricket-umpire-ball-counter",
    "version": "5.3.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cricketumpireballcounter",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "expo-router": {
      "source": "src/app"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.4dot6.cricketballandovercounter",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "5.3.3",
      "icon": "./assets/ios-icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["com.4dot6.cricketballandovercounter"]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#12c2e9",
        "foregroundImage": "./assets/ios-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cricketovercounterapp",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "com.cricketovercounterapp"
          },
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "versionCode": 53
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-4dot6.png",
          "resizeMode": "contain",
          "backgroundColor": "#12c2e9",
          "dark": {
            "backgroundColor": "#12c2e9"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "55989eef-1489-486e-8990-376fc18214d1"
      },
      "variant": "littlewicket"
    }
  }
}
