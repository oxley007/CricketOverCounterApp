{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "local"
  },
  "build": {
    "base-dev": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "base-dev-device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "base-preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "base-prod": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "umpire"
      }
    },
    "little-prod": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "littlewicket"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": false
    }
  },
  "submit": {
    "production": {}
  }
}
