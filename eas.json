{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "local"
  },
  "build": {
    "umpire-dev": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "umpire" }
    },

    "umpire-dev-device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "umpire" }
    },

    "umpire-prod-preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "umpire"
      }
    },

    "umpire-prod": {
      "extends": "production",
      "env": { "APP_VARIANT": "umpire" }
    },

    "littlewicket-dev": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "littlewicket" }
    },

    "littlewicket-dev-device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_VARIANT": "littlewicket" }
    },

    "littlewicket-prod-preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "littlewicket"
      }
    },

    "littlewicket-prod": {
      "extends": "production",
      "env": { "APP_VARIANT": "littlewicket" }
    },

    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": false
    }
  },
  "submit": {
    "production": {}
  }
}
